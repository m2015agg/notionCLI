{
  "name": "@m2015agg/notion-cli",
  "version": "0.5.1",
  "type": "module",
  "description": "CLI wrapper for the Notion API, designed for LLM/AI agent consumption",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "notion-cli": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "link": "npm run build && npm link",
    "postinstall": "node dist/index.js install --skip-shell 2>/dev/null || true",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@notionhq/client": "^5.13.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}